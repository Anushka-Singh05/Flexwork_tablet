                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="px-5 py-4 border-t border-slate-100 bg-white flex flex-col sm:flex-row items-center justify-between gap-3">
                    <div class="text-xs font-semibold text-slate-500">
                        Showing 1 to 3 of 3 entries
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="flex items-center gap-1">
                            <button class="w-8 h-8 rounded-lg border border-slate-200 flex items-center justify-center text-slate-300 cursor-not-allowed" disabled>
                                <i data-lucide="chevron-left" class="w-4 h-4"></i>
