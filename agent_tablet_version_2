        </main>
    </div>

    <!-- ===== ACTION DROPDOWN ===== -->
    <div id="actionDropdown" class="hidden fixed bg-white border border-slate-100 rounded-xl shadow-xl min-w-[130px] overflow-hidden flex-col divide-y divide-slate-50 py-1">
        <button id="openEditModalBtn" class="w-full text-left px-4 py-2.5 text-xs font-bold text-slate-700 hover:bg-slate-50 flex items-center gap-2 transition">
            <i data-lucide="edit-2" class="w-3.5 h-3.5 text-slate-400"></i> Edit
        </button>
        <button class="w-full text-left px-4 py-2.5 text-xs font-bold text-rose-600 hover:bg-rose-50 flex items-center gap-2 transition">
            <i data-lucide="trash-2" class="w-3.5 h-3.5 text-rose-400"></i> Delete
        </button>
    </div>

    <!-- ===== SLIDE-IN DRAWER MODAL ===== -->
    <div id="agentModal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm hidden items-center justify-end opacity-0 transition-opacity duration-300">
        <div id="modalContent" class="bg-white w-full max-w-md h-full shadow-2xl flex flex-col translate-x-full transition-transform duration-300 ease-out">
            <div class="p-5 border-b border-slate-100 flex items-center justify-between">
                <h2 id="modalTitle" class="text-base font-bold text-slate-900">Create Agent</h2>
                <button id="closeModalBtn" class="w-8 h-8 rounded-full flex items-center justify-center text-slate-400 hover:bg-slate-50 hover:text-slate-600 transition">
                    <i data-lucide="x" class="w-4 h-4"></i>
                </button>
            </div>
            <div class="p-5 flex-1 overflow-y-auto space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-600">First Name <span class="text-rose-500">*</span></label>
                        <input type="text" id="formFirstName" class="h-10 border border-slate-200 rounded-xl px-3.5 text-xs outline-none focus:border-[#6366F1] focus:ring-2 focus:ring-indigo-100 transition" />
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-600">Last Name <span class="text-rose-500">*</span></label>
                        <input type="text" id="formLastName" class="h-10 border border-slate-200 rounded-xl px-3.5 text-xs outline-none focus:border-[#6366F1] focus:ring-2 focus:ring-indigo-100 transition" />
                    </div>
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-bold text-slate-600">Email Address <span class="text-rose-500">*</span></label>
                    <input type="email" id="formEmail" class="h-10 border border-slate-200 rounded-xl px-3.5 text-xs outline-none focus:border-[#6366F1] focus:ring-2 focus:ring-indigo-100 transition" />
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-bold text-slate-600">Contact Number <span class="text-rose-500">*</span></label>
                    <div class="flex border border-slate-200 rounded-xl overflow-hidden focus-within:border-[#6366F1] focus-within:ring-2 focus-within:ring-indigo-100 transition">
                        <span class="bg-slate-50 border-r border-slate-200 px-3 flex items-center text-xs font-semibold text-slate-500 select-none">+91</span>
                        <input type="tel" id="formPhone" class="h-10 px-3 text-xs outline-none w-full" />
                    </div>
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-bold text-slate-600">City / Location <span class="text-rose-500">*</span></label>
                    <input type="text" id="formCity" class="h-10 border border-slate-200 rounded-xl px-3.5 text-xs outline-none focus:border-[#6366F1] focus:ring-2 focus:ring-indigo-100 transition" />
                </div>
            </div>
            <div class="p-4 px-5 border-t border-slate-100 bg-slate-50 flex justify-end gap-2.5">
                <button id="cancelModalBtn" class="px-4 h-10 border border-slate-200 bg-white rounded-xl text-xs font-bold text-slate-600 hover:bg-slate-50 transition">Cancel</button>
                <button id="saveModalBtn" class="px-5 h-10 bg-[#6366F1] text-white rounded-xl text-xs font-bold shadow-md hover:bg-indigo-600 transition">Save Data</button>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();

        /* ===== SIDEBAR ===== */
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const hamburgerBtn = document.getElementById('hamburgerBtn');
        const sidebarCloseBtn = document.getElementById('sidebarCloseBtn');

        function openSidebar() {
            sidebar.classList.add('open');
            overlay.classList.add('active');
        }
        function closeSidebar() {
            sidebar.classList.remove('open');
            overlay.classList.remove('active');
        }

        hamburgerBtn.addEventListener('click', openSidebar);
        sidebarCloseBtn.addEventListener('click', closeSidebar);
        overlay.addEventListener('click', closeSidebar);

        /* ===== SERVICES SUBMENU ===== */
        const servicesMenuToggle = document.getElementById('servicesMenuToggle');
        const servicesSubmenu = document.getElementById('servicesSubmenu');
        const servicesChevron = document.getElementById('servicesChevron');

        servicesMenuToggle.addEventListener('click', () => {
            const hidden = servicesSubmenu.classList.contains('hidden');
            servicesSubmenu.classList.toggle('hidden', !hidden);
            servicesChevron.classList.toggle('rotate-180', hidden);
        });

        /* ===== FILTER DROPDOWN ===== */
        const filterBtn = document.getElementById('filterBtn');
        const filterDropdown = document.getElementById('filterDropdown');
        const filterResetBtn = document.getElementById('filterResetBtn');
        const filterApplyBtn = document.getElementById('filterApplyBtn');

        function dismissFilter() {
            filterDropdown.classList.add('hidden');
            filterDropdown.classList.remove('flex');
            filterBtn.classList.remove('border-[#6366F1]', 'text-[#6366F1]');
        }

        filterBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            const isHidden = filterDropdown.classList.contains('hidden');
            if (isHidden) {
                filterDropdown.classList.remove('hidden');
                filterDropdown.classList.add('flex');
                filterDropdown.style.flexDirection = 'column';
                filterBtn.classList.add('border-[#6366F1]', 'text-[#6366F1]');
            } else {
                dismissFilter();
            }
        });

        filterResetBtn.addEventListener('click', () => {
            document.getElementById('filterLocation').value = '';
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterStartDate').value = '';
            document.getElementById('filterEndDate').value = '';
            dismissFilter();
        });
        filterApplyBtn.addEventListener('click', dismissFilter);

        /* ===== ACTION DROPDOWN ===== */
        const agentTableBody = document.getElementById('agentTableBody');
        const actionDropdown = document.getElementById('actionDropdown');
        const openEditModalBtn = document.getElementById('openEditModalBtn');
        let currentActionBtn = null;
        let currentRow = null;

        agentTableBody.addEventListener('click', (e) => {
            const btn = e.target.closest('.action-menu-btn');
            if (!btn) return;
            e.stopPropagation();
            currentActionBtn = btn;
            currentRow = btn.closest('tr');
            const rect = btn.getBoundingClientRect();
            actionDropdown.style.top = `${rect.bottom + window.scrollY + 4}px`;
            actionDropdown.style.left = `${Math.max(8, rect.left + window.scrollX - 90)}px`;
            actionDropdown.classList.remove('hidden');
            actionDropdown.style.display = 'flex';
            actionDropdown.style.flexDirection = 'column';
        });

        document.querySelector('.table-scroll-wrap').addEventListener('scroll', () => {
            actionDropdown.classList.add('hidden');
        });

        document.addEventListener('click', (e) => {
            if (currentActionBtn && !currentActionBtn.contains(e.target) && !actionDropdown.contains(e.target)) {
                actionDropdown.classList.add('hidden');
            }
            if (!filterBtn.contains(e.target) && !filterDropdown.contains(e.target)) {
                dismissFilter();
            }
        });

        /* ===== DRAWER MODAL ===== */
        const agentModal = document.getElementById('agentModal');
        const modalContent = document.getElementById('modalContent');
        const addAgentBtn = document.getElementById('addAgentBtn');
        const closeModalBtn = document.getElementById('closeModalBtn');
        const cancelModalBtn = document.getElementById('cancelModalBtn');
        const saveModalBtn = document.getElementById('saveModalBtn');
        const modalTitle = document.getElementById('modalTitle');
        const formFirstName = document.getElementById('formFirstName');
        const formLastName = document.getElementById('formLastName');
        const formEmail = document.getElementById('formEmail');
        const formPhone = document.getElementById('formPhone');
        const formCity = document.getElementById('formCity');
        let modalMode = 'create';

        function showDrawer() {
            agentModal.classList.remove('hidden');
            agentModal.style.display = 'flex';
            setTimeout(() => {
                agentModal.classList.remove('opacity-0');
                modalContent.classList.remove('translate-x-full');
            }, 15);
        }

        function hideDrawer() {
            agentModal.classList.add('opacity-0');
            modalContent.classList.add('translate-x-full');
            setTimeout(() => {
                agentModal.style.display = 'none';
                agentModal.classList.add('hidden');
            }, 300);
        }

        addAgentBtn.addEventListener('click', () => {
            modalMode = 'create';
            modalTitle.innerText = 'Create Agent';
            saveModalBtn.innerText = 'Save Data';
            formFirstName.value = ''; formLastName.value = ''; formEmail.value = ''; formPhone.value = ''; formCity.value = '';
            currentRow = null;
            showDrawer();
        });

        openEditModalBtn.addEventListener('click', () => {
            if (!currentRow) return;
            modalMode = 'edit';
            actionDropdown.classList.add('hidden');
            modalTitle.innerText = 'Edit Agent Overview';
            saveModalBtn.innerText = 'Save Changes';
            formFirstName.value = currentRow.querySelector('.cell-firstname').innerText.trim();
            formLastName.value = currentRow.querySelector('.cell-lastname').innerText.trim();
            formEmail.value = currentRow.querySelector('.cell-email').innerText.trim();
            formCity.value = currentRow.querySelector('.cell-location').innerText.trim();
            formPhone.value = currentRow.querySelector('.cell-mobile').innerText.replace('+91', '').trim();
            showDrawer();
        });

        saveModalBtn.addEventListener('click', () => {
            if (modalMode === 'edit' && currentRow) {
                currentRow.querySelector('.cell-firstname').innerText = formFirstName.value;
                currentRow.querySelector('.cell-lastname').innerText = formLastName.value;
                currentRow.querySelector('.cell-email').innerText = formEmail.value;
                currentRow.querySelector('.cell-mobile').innerText = `+91 ${formPhone.value.trim()}`;
                currentRow.querySelector('.cell-location').innerHTML = `<span class="location-pill">${formCity.value}</span>`;
            }
            hideDrawer();
        });

        closeModalBtn.addEventListener('click', hideDrawer);
        cancelModalBtn.addEventListener('click', hideDrawer);
    </script>
</body>
</html>
